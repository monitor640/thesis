# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Optional: Phone number for authentication
TELEGRAM_PHONE=+1234567890

# OpenAI — LLM benchmark (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
# Optional overrides:
# OPENAI_MODEL=gpt-5.4-nano
# LLM_MODEL=gpt-5.4-nano
#
# Do NOT set OPENAI_BASE_URL for normal OpenAI (a leftover Ollama URL causes 404 on gpt-*).
# For a custom gateway only: LLM_OPENAI_BASE_URL=https://example.com/v1
